<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div>Normal text</div><div><span style="--en-highlight:yellow;background-color: #ffef9e;">Yellow highlight</span></div><div><span style="--en-highlight:red;background-color: #fec1d0;">Red highlight</span></div><div><span style="--en-highlight:green;background-color: #ccffd4;">Green highlight</span></div><div><span style="--en-highlight:blue;background-color: #d4e2fc;">Blue highlight</span></div><div>More normal text</div></en-note>      ]]>
